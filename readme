drop database if exists ZooShop;
create database ZooShop;
use ZooShop;

create table users (
	user_id int primary key auto_increment,
    email varchar(100),
    password_hash varchar(255),
    fullname varchar(100)
);

create table categories (
	category_id int primary key auto_increment,
    category_name enum("Собаки", "Кішки", "Птахи") unique
);

create table subcategories (
	subcategory_id int primary key auto_increment,
    category_id int,
	subcategory_name enum ("Корм", "Іграшки", "Ласощі", "Здоров'я"),
    
    foreign key (category_id) references categories (category_id) on delete cascade 
);

create table products (
	product_id int primary key auto_increment,
    product_name varchar(50) not null,
    article varchar(50) unique not null,
    price decimal(10,2) not null,
    image_path varchar(255),
    subcategory_id int,
    
    foreign key (subcategory_id) references subcategories (subcategory_id) on delete cascade
);

create table food_products (
    product_id int primary key, 								-- ідентифікатор товару (зв'язок з таблицею products)
    animal_type enum('Собаки', 'Кішки', 'Птахи'), 				-- для якого типу тварини призначено корм
    food_type enum('Сухий', 'Вологий'), 						-- тип корму
    weight_grams int, 											-- вага продукту в грамах
    age_group enum('Молоді', 'Дорослі', 'Старі'), 				-- вікова категорія тварини
    foreign key (product_id) references products(product_id) on delete cascade
);

create table toy_products (
    product_id int primary key, 								-- ідентифікатор товару
    material enum('Гума', 'Пластик', 'Тканина'), 				-- матеріал іграшки
    size enum('Маленький', 'Середній', 'Великий'), 				-- розмір іграшки
    has_sound boolean, 											-- чи видає іграшка звук
    foreign key (product_id) references products(product_id) on delete cascade
);

create table treat_products (
    product_id int primary key, 								-- ідентифікатор товару
    animal_type enum('Собаки', 'Кішки', "Птахи"), 				-- для якого типу тварини
    purpose enum('Тренування', 'Нагорода', 'Для зубів'), 		-- призначення ласощів
    weight_grams int, 											-- вага в грамах
    foreign key (product_id) references products(product_id) on delete cascade
);

create table health_products (
    product_id int primary key, -- ідентифікатор товару
    product_type enum('Вітаміни', 'Ліки', 'Добавки'), 			-- тип продукту
    animal_type enum('Собаки', 'Кішки', 'Птахи'), 				-- для яких тварин
    form enum('Таблетки', 'Рідина', 'Порошок'), 				-- форма випуску
    foreign key (product_id) references products(product_id) on delete cascade
);

create table reviews (
	review_id int primary key auto_increment,
    content varchar(255) not null,
    review_date date not null,
	product_id int not null,
    user_id int not null,
    
    foreign key(user_id) references users(user_id) on delete cascade,
    foreign key(product_id) references products(product_id) on delete cascade
);

use zooshop;

